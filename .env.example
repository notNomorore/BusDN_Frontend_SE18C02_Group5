# Backend API Configuration
# Copy file này thành .env và chỉnh sửa theo môi trường của bạn
# Nếu không set, mặc định sẽ dùng http://localhost:3000

# Option 1: Chỉ định port (sẽ tự động dùng http://localhost:{port})
VITE_API_PORT=3000

# Option 2: Chỉ định full URL (ưu tiên hơn VITE_API_PORT nếu cả 2 đều có)
# VITE_API_URL=http://localhost:3000
