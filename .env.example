# Backend API configuration
# Copy this file to .env and adjust it for your local environment.
# If VITE_API_URL is not set, the frontend proxies to http://127.0.0.1:{VITE_API_PORT}.

# Option 1: set only the backend port
VITE_API_PORT=3000

# Option 2: set the full backend URL (takes precedence over VITE_API_PORT)
# VITE_API_URL=http://127.0.0.1:3000
